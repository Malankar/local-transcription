{
  "name": "local-transcription",
  "version": "0.1.0",
  "description": "Local-first Electron transcription app using Whisper via transformers.js",
  "main": "./out/main/index.js",
  "type": "commonjs",
  "author": "OpenAI Codex",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "pnpm build && electron-builder",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "nodejs-whisper": "^0.2.9",
    "electron": "35.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron-builder": "^25.0.0",
    "electron-vite": "5.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "nodejs-whisper",
      "protobufjs",
      "sharp"
    ]
